# === RESTOR-PC / EMAIL INFOMANIAK v11.8 ===
# Copie ces lignes dans backend/.env ou dans .env à la racine.
# Utilise le mot de passe d'application Infomaniak SMTP, pas forcément le mot de passe de connexion webmail.

MAIL_ENABLED=true
MAIL_PROVIDER=infomaniak
MAIL_SERVER=mail.infomaniak.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=contact@restor-pc.fr
MAIL_PASSWORD=A_REMPLACER_PAR_LE_MOT_DE_PASSE_APPLICATION_INFOMANIAK
MAIL_DEFAULT_SENDER=contact@restor-pc.fr
MAIL_FROM_NAME=RESTOR-PC

# Compatibilité anciennes routes SMTP_*
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=contact@restor-pc.fr
SMTP_PASSWORD=A_REMPLACER_PAR_LE_MOT_DE_PASSE_APPLICATION_INFOMANIAK
SMTP_SENDER=contact@restor-pc.fr
SMTP_TLS=true
SMTP_SSL=false
